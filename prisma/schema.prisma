generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                    String    @unique @db.VarChar(255)
  firstName                String?   @map("first_name") @db.VarChar(100)
  lastName                 String?   @map("last_name") @db.VarChar(100)
  businessIndustry         String?   @map("business_industry") @db.VarChar(150)
  role                     String    @default("user") @db.VarChar(20)
  status                   String    @default("active") @db.VarChar(20)
  passwordHash             String?   @map("password_hash")
  emailVerifiedAt          DateTime? @map("email_verified_at") @db.Timestamptz(6)
  emailVerificationToken   String?   @unique @map("email_verification_token")
  emailVerificationExpires DateTime? @map("email_verification_expires") @db.Timestamptz(6)
  passwordResetToken       String?   @unique @map("password_reset_token")
  passwordResetExpires     DateTime? @map("password_reset_expires") @db.Timestamptz(6)
  passwordSetupToken       String?   @unique @map("password_setup_token")
  passwordSetupExpires     DateTime? @map("password_setup_expires") @db.Timestamptz(6)
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  refreshTokens   RefreshToken[]
  waitlistEntry   WaitlistEntry?
  categories    Category[]
  leads         Lead[]
  snapshots     LeadSnapshot[]
  leadUploads      LeadUpload[]
  leadEvents       LeadEvent[]
  sentEmails       SentEmail[]
  emailIdentities  EmailIdentity[]

  @@index([role])
  @@index([status])
  @@map("users")
}

model WaitlistEntry {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName        String   @map("first_name") @db.VarChar(100)
  lastName         String   @map("last_name") @db.VarChar(100)
  email            String   @unique @db.VarChar(255)
  businessIndustry String   @map("business_industry") @db.VarChar(150)
  status           String   @default("pending") @db.VarChar(20)
  userId           String?  @unique @map("user_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("waitlist_entries")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Category {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @db.VarChar(100)
  offering  String
  statement String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads Lead[]

  @@index([userId])
  @@map("categories")
}

model LeadUpload {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  externalUploadId  String   @map("external_upload_id") @db.VarChar(36)
  defaultCategoryId String?  @map("default_category_id") @db.Uuid
  rowCount          Int      @default(0) @map("row_count")
  createdCount      Int      @default(0) @map("created_count")
  updatedCount      Int      @default(0) @map("updated_count")
  errorCount        Int      @default(0) @map("error_count")
  sourceLabel       String?  @map("source_label") @db.VarChar(100)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads Lead[]

  @@unique([userId, externalUploadId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("lead_uploads")
}

model LeadEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  leadId    String   @map("lead_id") @db.Uuid
  eventType String   @map("event_type") @db.VarChar(50)
  fromTier  String?  @map("from_tier") @db.VarChar(10)
  toTier    String?  @map("to_tier") @db.VarChar(10)
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, eventType, createdAt(sort: Desc)])
  @@index([leadId, createdAt(sort: Desc)])
  @@map("lead_events")
}

model Lead {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  uploadId         String?   @map("upload_id") @db.Uuid
  categoryId       String?   @map("category_id") @db.Uuid
  firstName        String    @map("first_name") @db.VarChar(100)
  lastName         String    @map("last_name") @db.VarChar(100)
  email            String    @db.VarChar(255)
  company          String?   @db.VarChar(255)
  jobTitle         String?   @map("job_title") @db.VarChar(255)
  linkedinUrl      String?   @map("linkedin_url") @db.VarChar(500)
  phone            String?   @db.VarChar(50)
  source           String?   @db.VarChar(100)
  initialMessage   String?   @map("initial_message")
  businessDetail   String?   @map("business_detail")
  score            Int       @default(0)
  tier             String    @default("cold") @db.VarChar(10)
  emailsSent       Int       @default(0) @map("emails_sent")
  emailsOpened     Int       @default(0) @map("emails_opened")
  linksClicked     Int       @default(0) @map("links_clicked")
  repliesReceived  Int       @default(0) @map("replies_received")
  bookingClicks    Int       @default(0) @map("booking_clicks")
  lastEventAt      DateTime? @map("last_event_at") @db.Timestamptz(6)
  lastEventType    String?   @map("last_event_type") @db.VarChar(50)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  upload   LeadUpload?   @relation(fields: [uploadId], references: [id], onDelete: SetNull)
  category Category?     @relation(fields: [categoryId], references: [id])
  snapshot   LeadSnapshot?
  events     LeadEvent[]
  sentEmails SentEmail[]

  @@unique([userId, email])
  @@index([userId])
  @@index([uploadId])
  @@map("leads")
}

model LeadSnapshot {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  leadId                String    @unique @map("lead_id") @db.Uuid
  currentScore          Int       @map("current_score")
  summary               String
  currentIntent         String    @map("current_intent") @db.VarChar(20)
  lastMeaningfulEvent   String?   @map("last_meaningful_event") @db.VarChar(50)
  suggestedEmailSubject String?   @map("suggested_email_subject")
  suggestedEmailBody    String?   @map("suggested_email_body")
  suggestedEmailSentAt  DateTime? @map("suggested_email_sent_at") @db.Timestamptz(6)
  llmModel              String?   @map("llm_model") @db.VarChar(100)
  tokenCost             Int?      @map("token_cost")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("lead_snapshots")
}

model EmailIdentity {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String   @map("user_id") @db.Uuid
  label                 String   @db.VarChar(100)
  fromName              String   @map("from_name") @db.VarChar(100)
  fromEmail             String   @map("from_email") @db.VarChar(255)
  replyTo               String?  @map("reply_to") @db.VarChar(255)
  providerType          String   @map("provider_type") @db.VarChar(20)
  domainVerified        Boolean  @default(false) @map("domain_verified")
  credentialsEncrypted  String   @map("credentials_encrypted")
  isDefault             Boolean  @default(false) @map("is_default")
  trackingEnabled       Boolean  @default(true) @map("tracking_enabled")
  replyHandlingMode     String   @default("webhook") @map("reply_handling_mode") @db.VarChar(20)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentEmails SentEmail[]

  @@index([userId])
  @@index([userId, isDefault])
  @@map("email_identities")
}

model SentEmail {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  leadId            String    @map("lead_id") @db.Uuid
  emailIdentityId   String?   @map("email_identity_id") @db.Uuid
  provider          String    @db.VarChar(20)
  providerMessageId String?   @map("provider_message_id") @db.VarChar(255)
  subject           String    @db.VarChar(500)
  bodyHtml          String    @map("body_html")
  bodyText          String    @map("body_text")
  linksJson         Json?     @map("links_json") @db.JsonB
  status            String    @default("pending") @db.VarChar(20)
  sentAt            DateTime? @map("sent_at") @db.Timestamptz(6)
  firstOpenedAt     DateTime? @map("first_opened_at") @db.Timestamptz(6)
  openCount         Int       @default(0) @map("open_count")
  firstClickedAt    DateTime? @map("first_clicked_at") @db.Timestamptz(6)
  clickCount        Int       @default(0) @map("click_count")
  repliedAt         DateTime? @map("replied_at") @db.Timestamptz(6)
  replySnippet      String?   @map("reply_snippet")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead          Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  emailIdentity EmailIdentity? @relation(fields: [emailIdentityId], references: [id], onDelete: SetNull)

  @@index([userId, sentAt(sort: Desc)])
  @@index([leadId, sentAt(sort: Desc)])
  @@index([emailIdentityId])
  @@map("sent_emails")
}
