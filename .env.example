PORT=5000

# --- Neon PostgreSQL (Prisma) ---
# Use your Neon connection string (include ?sslmode=require)
# Tip: for `npm run db:migrate`, Neon recommends the *direct* URL (no "-pooler" in host).
# The pooled URL works for `npm run dev` and often for `npm run db:push`.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# LLM profiling (snapshot + suggested email)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Resend — https://resend.com/docs/send-with-nodejs
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Sales <onboarding@yourdomain.com>
